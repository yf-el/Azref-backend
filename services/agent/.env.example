STAGE=dev
LOG_LEVEL=INFO

# Postgres (read-only DB with the 60K+ legal documents)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# LLM provider API keys (at least one must be set for the cascade to work)
CEREBRAS_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# Clerk auth (required to validate JWTs on /api/v1/chat)
CLERK_ISSUER=https://your-tenant.clerk.accounts.dev
# Optional, defaults to ${CLERK_ISSUER}/.well-known/jwks.json
CLERK_JWKS_URL=

# CORS (comma-separated origins for production)
CORS_ORIGINS=https://azref.ma,https://www.azref.ma,https://huquqai.com,https://www.huquqai.com

# Agent tuning
MAX_AGENT_STEPS=5
DEFAULT_TEMPERATURE=0.3
DEFAULT_MAX_TOKENS=3000
