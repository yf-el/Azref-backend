# Local dev only. Production values live in AWS Secrets Manager.

# users-service
DATABASE_URL=postgresql+asyncpg://azref:azref@postgres:5432/azref
LOG_LEVEL=INFO

# Clerk (lus directement par libs/auth_clerk)
# Trouver l'issuer dans Clerk Dashboard > API Keys > "Show JWT public key" > issuer URL
CLERK_ISSUER=https://your-app.clerk.accounts.dev
# Optionnel — si non défini, dérivé en {CLERK_ISSUER}/.well-known/jwks.json
# CLERK_JWKS_URL=
